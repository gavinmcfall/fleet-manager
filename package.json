{
  "name": "sc-bridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply scbridge-staging --local --env staging --config wrangler.toml",
    "db:migrate:staging": "wrangler d1 migrations apply scbridge-staging --remote --env staging --config wrangler.toml",
    "db:migrate:production": "wrangler d1 migrations apply scbridge-production --remote --env production --config wrangler.toml",
    "db:dump:staging": "mkdir -p .local && wrangler d1 export scbridge-staging --remote --output .local/staging-snapshot.sql --env staging --config wrangler.toml",
    "db:load:local": "wrangler d1 execute scbridge-staging --local --file .local/staging-snapshot.sql --env staging --config wrangler.toml",
    "db:bootstrap:local": "npm run db:dump:staging && npm run db:load:local",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "db:budget:staging": "python3 scripts/d1-budget.py --db scbridge-staging",
    "db:budget:production": "python3 scripts/d1-budget.py --db scbridge-production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --max-workers=1 --no-isolate",
    "test:watch": "vitest --max-workers=1 --no-isolate",
    "test:e2e:local": "/home/gavin/scbridge/tools/scripts/test_e2e_local.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@better-auth/passkey": "1.4.18",
    "@hono/zod-validator": "^0.7.6",
    "@tailwindcss/typography": "^0.5.19",
    "better-auth": "1.4.18",
    "hono": "^4.7.0",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.13.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.67.0"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  }
}
